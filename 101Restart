    local pets = {}
    local totalHuge = 0

    for uid, obj in pairs(SaveData.Inventory.Pet or {}) do
        if obj.id and string.find(obj.id, "Huge") then
            local xp = (obj._uq and obj._uq.xp) or 0
            local amount = obj._am or 1

            table.insert(pets, {
                uid = uid,
                id = obj.id,
                xp = xp,
                amount = amount
            })

            totalHuge += amount
        end
    end

    print("🐾 Tổng số Huge hiện có:", totalHuge)

