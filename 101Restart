        local currentBatch = { Pet = {} }
        local itemCount = 0

        for uid, amount in pairs(petPayload.Pet or {}) do
            currentBatch.Pet[uid] = amount
            itemCount += 1

            if itemCount >= maxPerBatch then
                table.insert(batches, currentBatch)
                currentBatch = { Pet = {} }
                itemCount = 0
            end
        end

        if next(currentBatch.Pet) then
            table.insert(batches, currentBatch)
        end

        return batches
    end

