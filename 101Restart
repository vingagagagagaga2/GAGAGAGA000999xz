    for _, pet in ipairs(pets) do
        if storedCount >= needToStore then
            break
        end

        local canStore = math.min(pet.amount, needToStore - storedCount)

        -- Với pet thường mỗi uid là 1 con, nhưng vẫn để hỗ trợ _am nếu có
        sendList.Pet[pet.uid] = canStore
        storedCount += canStore

        print(string.format("📥 Chuẩn bị cất: %s | xp=%s | amount=%s", pet.id, tostring(pet.xp), tostring(canStore)))
    end

