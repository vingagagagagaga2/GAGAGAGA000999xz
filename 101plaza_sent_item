local function parseNumber(v)
	if type(v) == "number" then
		return v
	end
	if type(v) ~= "string" then
		return 0
	end

	v = v:lower()
	local mult = {k = 1e3, m = 1e6, b = 1e9, t = 1e12}
	local num = tonumber(v:match("[%d%.]+")) or 0
	local suffix = v:match("[a-z]+")
	return num * (mult[suffix] or 1)
end

local function mailboxSend(target, message, class, uid, amount)
	return NetworkLib.Invoke("Mailbox: Send", target, message, class, uid, amount)
end

