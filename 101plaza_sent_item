local function findMatchingItems(class, itemId, allVariants, requiredTN)
	local inv = getInventory()
	local sub = inv[class]
	local results = {}

	if type(sub) ~= "table" then
		return results
	end

	for uid, v in pairs(sub) do
		if type(v) == "table" and v.id then
			local matched = allVariants and string.find(v.id, itemId, 1, true) or (v.id == itemId)
			if matched and (requiredTN == nil or v.tn == requiredTN) then
				table.insert(results, {
					UID = uid,
					ID = v.id,
					PT = v.pt,
					SH = v.sh,
					TN = v.tn,
					Count = tonumber(v._am) or 1,
					Class = class,
				})
			end
		end
	end

	return results
end

local function sendConfiguredItems()
	local message = getRandomMessage()

	for _, config in pairs(SETTINGS_SENT_ITEM) do
		local class = config.Class
		local itemId = config.Id
		local minAmount = parseNumber(config.MinAmount)
		local keepAmount = config.keepAmount and parseNumber(config.keepAmount) or 0
		local matched = findMatchingItems(class, itemId, config.AllVariants or false, config.TN)

		for _, item in ipairs(matched) do
			if item.Count >= minAmount then
				local sendCount = item.Count
				if keepAmount > 0 and item.Count > keepAmount then
					sendCount = item.Count - keepAmount
				end

				if sendCount > 0 then
					local ok, err = pcall(function()
						return mailboxSend(NAME_USER_SEND, message, class, item.UID, sendCount)
					end)

					if not ok then
						warn("[Send Item] Lỗi gửi:", item.ID, err)
					end

					task.wait(2)
				end
			end
		end
	end
end

local function parsePetName(rawName)
	local name = rawName
	local isShiny = false
	local pt = false

	if name:find("Shiny Rainbow ", 1, true) == 1 then
		isShiny = true
		pt = 2
		name = name:gsub("^Shiny Rainbow ", "")
	elseif name:find("Shiny Golden ", 1, true) == 1 then
		isShiny = true
		pt = 1
		name = name:gsub("^Shiny Golden ", "")
	elseif name:find("Rainbow ", 1, true) == 1 then
		pt = 2
		name = name:gsub("^Rainbow ", "")
	elseif name:find("Golden ", 1, true) == 1 then
		pt = 1
		name = name:gsub("^Golden ", "")
	elseif name:find("Shiny ", 1, true) == 1 then
		isShiny = true
		name = name:gsub("^Shiny ", "")
	end

	return name, isShiny, pt
end

local function findPets(baseName, wantShiny, wantPt)
	local inv = getInventory()
	local petTable = inv.Pet
	local results = {}

	if type(petTable) ~= "table" then
		return results
	end

	for uid, v in pairs(petTable) do
		if type(v) == "table" and v.id == baseName then
			local ok = true

			if wantPt ~= false and v.pt ~= wantPt then
				ok = false
			end
			if wantPt == false and (v.pt == 1 or v.pt == 2) then
				ok = false
			end

			if wantShiny and v.sh ~= true then
				ok = false
			end
			if not wantShiny and v.sh == true then
				ok = false
			end

			if ok then
				table.insert(results, {
					UID = uid,
					ID = v.id,
					PT = v.pt,
					SH = v.sh,
					Count = tonumber(v._am) or 1,
				})
			end
		end
	end

	return results
end

local function sendConfiguredPets()
	for rawPetName, cfg in pairs(SETTINGS_SENT_PET) do
		local baseName, wantShiny, wantPt = parsePetName(rawPetName)
		local found = findPets(baseName, wantShiny, wantPt)

		local totalCount = 0
		for _, pet in ipairs(found) do
			totalCount += pet.Count
		end

		if totalCount < cfg.Soluong_Yeu_cau then
			warn("[Send Pet] Không đủ pet:", rawPetName, " | Có:", totalCount)
		else
			local sendAmount = totalCount
			if rawPetName:find("Huge", 1, true) then
				sendAmount = math.max(0, totalCount - 1)
			elseif cfg.Soluong_Yeu_cau == 1 then
				sendAmount = math.max(0, totalCount - 1)
			end

			if sendAmount <= 0 then
				continue
			end

			local message = string.format("Happy birthday %s! You received an excess pet: %s", NAME_USER_SEND, rawPetName)

			for _, pet in ipairs(found) do
				if sendAmount <= 0 then
					break
				end

				local chunk = math.min(sendAmount, pet.Count)
				local ok, err = pcall(function()
					return mailboxSend(NAME_USER_SEND, message, "Pet", pet.UID, chunk)
				end)

				if ok then
					sendAmount -= chunk
					task.wait(5)
				else
					warn("[Send Pet] Lỗi gửi:", rawPetName, err)
				end
			end
		end
	end
end

local function getCurrencyUIDAndAmount(currencyId)
	local inv = getInventory()
	local currencyTable = inv.Currency

	if type(currencyTable) ~= "table" then
		return nil, 0
	end

	for uid, v in pairs(currencyTable) do
		if type(v) == "table" and v.id == currencyId then
			local amount = tonumber(v._am or v.amount or v.Amount or 0) or 0
			return uid, amount
		end
	end

	return nil, 0
end

local function sendConfiguredCurrencies()
	local message = getRandomMessage()

	for _, config in pairs(SETTINGS_SENT_CURRENCY) do
		local currencyUID, currentAmount = getCurrencyUIDAndAmount(config.Id)
		local minAmount = parseNumber(config.MinAmount or 0)
		local keepAmount = parseNumber(config.KeepAmount or config.keepAmount or 0)

		if not currencyUID then
			warn("[Send Currency] Không tìm thấy UID:", config.Id)
		elseif currentAmount >= minAmount then
			local sendAmount = currentAmount - keepAmount

			if sendAmount > 0 then
				local ok, err = pcall(function()
					return mailboxSend(NAME_USER_SEND, message, "Currency", currencyUID, sendAmount)
				end)

				if ok then
					print(string.format("[Send Currency] Đã gửi %s x%s", config.Id, tostring(sendAmount)))
				else
					warn("[Send Currency] Lỗi gửi:", config.Id, err)
				end
			end
		end
	end
end

