local function getOffline()
	if not isfile or not isfile(FILE_NAME) then
		writefile(FILE_NAME, "0")
		return 0
	end

	local val = tonumber(readfile(FILE_NAME))
	if val == nil then
		writefile(FILE_NAME, "0")
		return 0
	end

	return val
end

local function setOffline(v)
	writefile(FILE_NAME, tostring(v))
end

